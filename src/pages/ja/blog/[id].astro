---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => p.data.lang === 'ja')
    .map((post) => ({
      params: { id: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} lang="ja">
  <section class="post-hero">
    <div class="container">
      <a href="/ja/blog" class="back-link">← ブログ一覧へ</a>
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <time>{post.data.date.toLocaleDateString('ja-JP')}</time>
        {post.data.tags && post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </section>

  <article class="section">
    <div class="container post-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post-hero {
    background: var(--color-primary);
    color: #fff;
    padding: 8rem 0 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: #fff;
    text-decoration: none;
  }

  .post-hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .post-meta time {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .tag {
    font-size: 0.7rem;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .section {
    padding: 4rem 0 6rem;
  }

  .post-body {
    max-width: 750px;
    margin: 0 auto;
    font-size: 1rem;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
    color: var(--color-primary);
    font-weight: 700;
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    margin: 2rem 0 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .post-body :global(p) {
    margin-bottom: 1.2rem;
    color: var(--color-text);
    line-height: 1.8;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: 1.2rem;
    padding-left: 1.5rem;
    color: var(--color-text);
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.2rem;
    margin: 1.5rem 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  .post-body :global(code) {
    background: var(--color-bg-light);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .post-body :global(pre) {
    background: var(--color-bg-dark);
    color: #e0e0e0;
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-body :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
  }
</style>

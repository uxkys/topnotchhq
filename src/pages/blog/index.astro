---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog" description="TopNotch HQ のブログ記事一覧">
  <section class="blog-hero">
    <div class="container">
      <h1>Blog</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 && <p class="no-posts">まだ記事がありません。</p>}
      <div class="posts-grid">
        {posts.map((post) => (
          <article class="post-card">
            <a href={`/blog/${post.id}`}>
              <h2>{post.data.title}</h2>
              <p class="post-date">{post.data.date.toLocaleDateString('ja-JP')}</p>
              <p class="post-excerpt">{post.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background: var(--color-primary);
    color: #fff;
    padding: 8rem 0 3rem;
    text-align: center;
  }

  .blog-hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
  }

  .no-posts {
    text-align: center;
    color: var(--color-text-light);
  }

  .posts-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 2rem;
    transition: box-shadow 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .post-card a {
    text-decoration: none;
    color: inherit;
  }

  .post-card h2 {
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-bottom: 0.8rem;
  }

  .post-excerpt {
    color: var(--color-text-light);
    font-size: 0.95rem;
  }
</style>

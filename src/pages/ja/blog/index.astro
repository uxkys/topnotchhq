---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === 'ja')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="ブログ" description="Top Notch Inc. のブログ・事例紹介" lang="ja">
  <section class="blog-hero">
    <div class="container">
      <p class="blog-label">事例紹介・コラム</p>
      <h1>ブログ</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 && <p class="no-posts">まだ記事がありません。</p>}
      <div class="posts-grid">
        {posts.map((post) => (
          <article class="post-card">
            <a href={`/ja/blog/${post.id}`}>
              <div class="post-meta">
                <time>{post.data.date.toLocaleDateString('ja-JP')}</time>
                {post.data.tags && post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <h2>{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <span class="read-more">続きを読む →</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background: var(--color-primary);
    color: #fff;
    padding: 8rem 0 3rem;
  }

  .blog-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.8rem;
  }

  .blog-hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
  }

  .section {
    padding: 4rem 0 6rem;
  }

  .no-posts {
    text-align: center;
    color: var(--color-text-light);
    padding: 3rem 0;
  }

  .posts-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 2rem;
    transition: box-shadow 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .post-card a {
    text-decoration: none;
    color: inherit;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.8rem;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .tag {
    font-size: 0.7rem;
    background: var(--color-bg-light);
    color: var(--color-accent);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .post-card h2 {
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-bottom: 0.6rem;
    line-height: 1.4;
  }

  .post-excerpt {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .read-more {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
  }
</style>

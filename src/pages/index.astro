---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Top Notch Inc. — Advisory firm specializing in international business development and brand strategy across European and Asian markets."
  lang="en"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="hero-label">International Business Advisory</p>
      <h1>We read the market, design the strategy,<br />build partnerships, and execute the business.</h1>
      <p class="hero-sub">
        We compress time and risk in global expansion<br />
        and lower the barriers to entering the Japanese market.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">Get in Touch</a>
        <a href="#about" class="btn-secondary">Learn More</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section">
    <div class="container about-grid">
      <div class="about-content">
        <h2 class="section-label">About Us</h2>
        <h3 class="section-heading">Practical expertise in international business</h3>
        <p>
          Top Notch Inc. is an advisory firm specializing in international business
          development and brand strategy. With extensive experience in supporting
          European brands entering Japan, assisting Japanese companies in overseas
          expansion, and building brands in Asian markets, we provide practical
          and strategic business support.
        </p>
        <p>
          Leveraging hands-on experience and international networks, we help
          companies expand their opportunities beyond borders.
        </p>
      </div>
      <div class="about-image">
        <img src="/images/TopNotchInc_icon.avif" alt="Top Notch Inc." />
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="section section-alt">
    <div class="container">
      <h2 class="section-label center">Services</h2>
      <h3 class="section-heading center">What We Offer</h3>
      <div class="services-grid">
        <a href="/services/market-research" class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h4>Market Research</h4>
          <p>In-depth analysis of target markets across Asia and Europe to identify opportunities and mitigate risks.</p>
          <span class="service-link">Learn more →</span>
        </a>
        <a href="/services/brand-strategy" class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h4>Brand Strategy</h4>
          <p>Strategic brand positioning and development tailored for international markets, drawing on decades of luxury and consumer brand experience.</p>
          <span class="service-link">Learn more →</span>
        </a>
        <a href="/services/partner-development" class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h4>Partner Development</h4>
          <p>Execution-driven partner development based on real-world experience — beyond introductions to building real, sustainable partnerships.</p>
          <span class="service-link">Learn more →</span>
        </a>
        <a href="/services/business-development" class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h4>Business Development</h4>
          <p>Execution-driven business development that goes beyond strategy — driving actual sales, negotiation, and market validation.</p>
          <span class="service-link">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Founder -->
  <section id="founder" class="section">
    <div class="container founder-grid">
      <div class="founder-photo">
        <img src="/images/topnotch_babasaki_photo001.avif" alt="Osamu Babasaki" />
      </div>
      <div class="founder-content">
        <h2 class="section-label">Founder</h2>
        <h3 class="section-heading">Osamu Babasaki</h3>
        <p class="founder-title">International Business & Brand Advisor</p>
        <p>
          With a career spanning diplomacy, government service, and private enterprise,
          Osamu brings a unique perspective to international business advisory.
        </p>
        <ul class="founder-highlights">
          <li>Served as diplomat (Consul) at the Consulate General of Japan in West Berlin, Germany</li>
          <li>Managed import operations for European luxury brands including Herend (Hungary) and Moser (Czech Republic)</li>
          <li>Supported Yumi Katsura Paris operations, including Paris, Singapore, and Bangkok collections</li>
          <li>Invited by the Royal Thai Embassy to deliver brand strategy lectures to 60 young entrepreneurs in Bangkok</li>
          <li>Ongoing advisory relationship with Thailand's DITP and the Royal Thai Embassy in Tokyo</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section section-dark">
    <div class="container contact-inner">
      <h2 class="section-label center light">Contact</h2>
      <h3 class="section-heading center light">Let's discuss your next move</h3>
      <p class="contact-desc">
        Whether you're exploring new markets or looking to strengthen your international
        brand presence, we'd love to hear from you.
      </p>
      <a href="mailto:hello@topnotchhq.com" class="btn-primary btn-light">hello@topnotchhq.com</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--color-primary);
    color: #fff;
    padding: 10rem 0 6rem;
  }

  .hero-inner {
    max-width: 750px;
  }

  .hero-label {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 700px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.75rem 1.8rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--color-accent-dark);
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-block;
    color: rgba(255, 255, 255, 0.7);
    padding: 0.75rem 1.8rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
  }

  /* Sections */
  .section {
    padding: 6rem 0;
  }

  .section-alt {
    background: var(--color-bg-light);
  }

  .section-dark {
    background: var(--color-primary);
    color: #fff;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 0.8rem;
  }

  .section-label.light {
    color: rgba(255, 255, 255, 0.5);
  }

  .section-label.center {
    text-align: center;
  }

  .section-heading {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .section-heading.center {
    text-align: center;
  }

  .section-heading.light {
    color: #fff;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: center;
  }

  .about-content p {
    color: var(--color-text-light);
    margin-bottom: 1rem;
    font-size: 1rem;
  }

  .about-image {
    display: flex;
    justify-content: center;
  }

  .about-image img {
    width: 200px;
    height: 200px;
    object-fit: contain;
  }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .service-card {
    background: #fff;
    padding: 2rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s, transform 0.2s;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .service-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    text-decoration: none;
  }

  a.service-card:hover {
    transform: translateY(-2px);
  }

  .service-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .service-icon {
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .service-card h4 {
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .service-card p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* Founder */
  .founder-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .founder-photo img {
    width: 100%;
    border-radius: 12px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .founder-title {
    font-size: 1rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 1.2rem;
  }

  .founder-content p {
    color: var(--color-text-light);
    margin-bottom: 1.2rem;
    font-size: 0.95rem;
  }

  .founder-highlights {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
  }

  .founder-highlights li {
    position: relative;
    padding-left: 1.2rem;
    margin-bottom: 0.7rem;
    color: var(--color-text-light);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .founder-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 5px;
    height: 5px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  /* Contact */
  .contact-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-desc {
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .btn-light {
    background: #fff;
    color: var(--color-primary);
  }

  .btn-light:hover {
    background: #f3f4f6;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 8rem 0 4rem;
    }

    .hero h1 {
      font-size: 1.7rem;
    }

    .hero-sub br {
      display: none;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-image {
      order: -1;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .founder-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .founder-photo img {
      max-width: 250px;
    }

    .section-heading {
      font-size: 1.6rem;
    }
  }
</style>

---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'ja';
  label: string;
  heading: string;
  intro?: string;
}

const { title, description, lang = 'en', label, heading, intro } = Astro.props;
const isJa = lang === 'ja';
const backLink = isJa ? '/ja/#services' : '/#services';
const backLabel = isJa ? '← サービス一覧へ' : '← Back to Services';
---

<BaseLayout title={title} description={description} lang={lang}>
  <section class="service-hero">
    <div class="container">
      <a href={backLink} class="back-link">{backLabel}</a>
      <p class="service-label">{label}</p>
      <h1>{heading}</h1>
      {intro && <p class="service-intro">{intro}</p>}
    </div>
  </section>

  <article class="service-section">
    <div class="container service-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .service-hero {
    background: var(--color-primary);
    color: #fff;
    padding: 8rem 0 3.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: #fff;
    text-decoration: none;
  }

  .service-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.8rem;
  }

  .service-hero h1 {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .service-intro {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 750px;
    line-height: 1.8;
  }

  .service-section {
    padding: 4rem 0 6rem;
  }

  .service-body {
    max-width: 820px;
    margin: 0 auto;
    font-size: 1rem;
    color: var(--color-text);
  }

  .service-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.01em;
    line-height: 1.4;
  }

  .service-body :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 2rem 0 0.8rem;
    line-height: 1.4;
  }

  .service-body :global(h4) {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 1.5rem 0 0.6rem;
  }

  .service-body :global(p) {
    margin-bottom: 1.2rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .service-body :global(ul),
  .service-body :global(ol) {
    margin: 0 0 1.5rem 1.5rem;
    line-height: 1.9;
  }

  .service-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .service-body :global(a) {
    color: var(--color-accent);
    word-break: break-all;
  }

  .service-body :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .service-body :global(.brand-block) {
    background: var(--color-bg-light);
    padding: 1.5rem 1.8rem;
    border-radius: 10px;
    border-left: 3px solid var(--color-accent);
    margin-bottom: 1.2rem;
  }

  .service-body :global(.brand-block h4) {
    margin-top: 0;
  }

  .service-body :global(.brand-block p) {
    margin-bottom: 0.4rem;
    font-size: 0.95rem;
  }

  .service-body :global(.brand-block a) {
    font-size: 0.9rem;
  }

  .service-body :global(.highlight-box) {
    background: #f0f5ff;
    padding: 1.5rem 1.8rem;
    border-radius: 10px;
    margin: 1.8rem 0;
    border: 1px solid #dbe4ff;
  }

  .service-body :global(.highlight-box p:last-child) {
    margin-bottom: 0;
  }

  .service-body :global(.case-block) {
    background: var(--color-bg-light);
    padding: 1.8rem 2rem;
    border-radius: 10px;
    margin: 2rem 0;
  }

  .service-body :global(.case-block h3) {
    margin-top: 0;
    color: var(--color-accent);
  }

  .service-body :global(.divider-heading) {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 3rem 0 1.5rem;
  }

  @media (max-width: 768px) {
    .service-hero h1 {
      font-size: 1.8rem;
    }

    .service-intro {
      font-size: 0.95rem;
    }
  }
</style>
